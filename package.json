{
  "name": "@designbycode/uploader-react",
  "version": "1.0.2",
  "description": "React hooks for @designbycode/uploader-core - a framework-agnostic file uploader library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "uploader",
    "upload",
    "react",
    "file-upload",
    "hooks",
    "drag-and-drop"
  ],
  "license": "MIT",
  "author": "designbycode",
  "repository": {
    "type": "git",
    "url": "https://github.com/designbycode/uploader-react"
  },
  "homepage": "https://github.com/designbycode/uploader-react#readme",
  "bugs": {
    "url": "https://github.com/designbycode/uploader-react/issues"
  },
  "dependencies": {
    "@designbycode/uploader-core": "^1.0.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^18.3.0",
    "jsdom": "^29.0.1",
    "react": "^18.3.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.1"
  }
}
